/target
# Rust example workspaces each produce their own target/ and Cargo.lock
examples/rust/*/target/
# LMDB runtime data created by Rust SDK pipelines/tests
.grepify_db/
examples/rust/files_transform/output_html/
examples/rust/pdf_to_markdown/out/
# Downloaded embedding model cache (fastembed) — e.g. code-embedding example
.fastembed_cache/

# Byte-compiled / optimized / DLL files
__pycache__/
.pytest_cache/
*.py[cod]

# C extensions
*.so

# Distribution / packaging
.venv*/
dist/
uv.lock

.DS_Store

*.egg-info/

/.vscode
/*.session.sql

.mypy_cache
.dmypy.json

# LMDB files
*.mdb

# Output of `grepify eval`
examples/**/eval_*
examples/**/uv.lock
**/lancedb_data/

# Grepify Code (ccc)
/.grepify_code/

# Claude Code local state
.claude/*.lock

# Node / napi build artifacts (TypeScript SDK)
node_modules/
*.node
packages/node/npm/
packages/node/index.js
packages/node/index.d.ts

# Parity/benchmark scratch
tests/parity/.work/
benchmarks/bindings/**/results.json
